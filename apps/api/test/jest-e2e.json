{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": {
          "esModuleInterop": true,
          "module": "CommonJS",
          "moduleResolution": "Node",
          "experimentalDecorators": true,
          "emitDecoratorMetadata": true,
          "strict": true
        }
      }
    ]
  },
  "testEnvironment": "node",
  "setupFiles": ["dotenv/config"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
