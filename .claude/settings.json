{
  "enabledMcpjsonServers": ["playwright"],
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Bash(npm run test)",
      "Bash(npm run test:e2e)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npx prisma *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; npx prettier --write \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}
